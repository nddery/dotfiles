export DOTFILES="$HOME/Git/dotfiles"

source $DOTFILES/zsh/alias.zsh
source $DOTFILES/zsh/bindkeys.zsh
source $DOTFILES/zsh/completion.zsh
source $DOTFILES/zsh/functions.zsh
source $DOTFILES/zsh/history.zsh

source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
# Static bundle: regenerate the flat plugin file only when plugins.txt changes,
# then source it — much faster than running `antidote load` every startup.
zbundle=$HOME/.zsh_plugins.zsh
if [[ ! $zbundle -nt ${DOTFILES}/zsh/plugins.txt ]]; then
  antidote bundle <${DOTFILES}/zsh/plugins.txt >| $zbundle
fi
source $zbundle

if [ -f ~/.zshlocalrc ]; then
  source ~/.zshlocalrc
fi;

[ -x "$(command -v fzf)" ] && source <(fzf --zsh)

# zoxide provides `z`/`zi` for jumping and feeds directory entries to sesh
# (replaces the older rupa/z plugin).
[ -x "$(command -v zoxide)" ] && eval "$(zoxide init zsh)"

ulimit -S -n 2048

export EDITOR=nvim
export VISUAL=nvim

export HOMEBREW_CASK_OPTS="--appdir=/Applications"

export FZF_DEFAULT_COMMAND="rg --files --hidden --glob '!.git'"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

export PATH="/opt/homebrew/opt/openjdk@17/bin:$PATH"

