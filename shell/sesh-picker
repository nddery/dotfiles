#!/usr/bin/env bash
#
# sesh-picker — interactive sesh session switcher.
#
# Meant to live in a small tmux pane (see the `session-created` hook in
# tmux.conf), but works as a standalone command too: run `sesh-picker`
# anywhere to fuzzy-pick a session and switch to it.
#
# Loops so the picker reappears after each switch. Press Esc to dismiss it
# (which closes the pane); reopen with the tmux binding: <prefix> T.

# Mark this pane so tmux can auto-close the window once the picker is the only
# pane left (see the window-layout-changed hook in tmux.conf).
[ -n "$TMUX_PANE" ] && tmux set-option -p -t "$TMUX_PANE" @sesh_picker 1 2>/dev/null

# Default to active (running) tmux sessions only; the fuller list is one
# keystroke away via ^a. sesh errors if a zoxide source is requested but zoxide
# isn't installed, so ^a's "all" view and the ^x (dirs) binding are gated on it.
default='sesh list -t --icons'             # active tmux sessions only
if command -v zoxide >/dev/null 2>&1; then
  all='sesh list -d --icons'               # tmux + config + zoxide dirs, deduped
  header='^a all  ^t tmux  ^g conf  ^x dir'
  extra_binds=(--bind 'ctrl-x:change-prompt(📁 )+reload(sesh list -z --icons)')
else
  all='sesh list -t -c -d --icons'         # tmux + config only, deduped
  header='^a all  ^t tmux  ^g conf'
  extra_binds=()
fi

# Reload whichever source matches the current prompt, so a refresh keeps you on
# the view you're looking at. Triggered by f5, which tmux sends on pane-focus-in
# (see tmux.conf) so the list is fresh every time you return to the picker.
reload_current="case \"\$FZF_PROMPT\" in *🌐*) $all ;; *⚙*) sesh list -c --icons ;; *📁*) sesh list -z --icons ;; *) sesh list -t --icons ;; esac"

while true; do
  session=$(
    $default | fzf \
      --ansi --no-sort --layout=reverse --border \
      --border-label ' sesh ' --prompt '⚡ ' \
      --header "$header" \
      --bind 'tab:down,btab:up' \
      --bind 'ctrl-l:execute-silent(tmux select-pane -R)' \
      --bind "f5:reload($reload_current)" \
      --bind "ctrl-a:change-prompt(🌐 )+reload($all)" \
      --bind 'ctrl-t:change-prompt(🪟 )+reload(sesh list -t --icons)' \
      --bind 'ctrl-g:change-prompt(⚙  )+reload(sesh list -c --icons)' \
      "${extra_binds[@]}"
  ) || break
  [ -n "$session" ] && sesh connect "$session"
done
