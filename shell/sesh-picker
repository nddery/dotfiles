#!/usr/bin/env bash
#
# sesh-picker — interactive sesh session switcher.
#
# Meant to live in a small tmux pane (see the hooks in tmux.conf), but works as
# a standalone command too: run `sesh-picker` to fuzzy-pick a session.
# Reopen a dismissed picker with the tmux binding <prefix> e.
#
# Subcommands (used by the picker itself and by tmux hooks):
#   sesh-picker --list <tmux|all|config|dir>   print one view (TARGET<TAB>DISPLAY)
#   sesh-picker --refresh-all                  refresh on-screen picker panes
#
# Each list line is tab-delimited: field 1 is what `sesh connect` receives,
# field 2 is the (colored) display. fzf shows only field 2 (--with-nth 2) and
# strips ANSI from what it returns, so the connect target stays clean.

self="$0"

# ---- views -----------------------------------------------------------------

dup() { awk '{ print $0 "\t" $0 }'; }   # plain views: display == connect target

# Active tmux sessions, enriched: ▶ marks the current session (bold), the git
# branch is shown dim, and 🔔 flags a session with a pending bell alert.
list_tmux() {
  command -v jq >/dev/null 2>&1 || { sesh list -t --icons | sort -f | dup; return; }
  local cur bells
  cur=$(tmux display-message -p -t "${TMUX_PANE:-}" '#S' 2>/dev/null)
  bells=$(tmux list-sessions -f '#{m:*!*,#{session_alerts}}' -F '#{session_name}' 2>/dev/null)
  sesh list -t -j 2>/dev/null | jq -r 'sort_by(.Name | ascii_downcase) | .[] | [.Name, .Path] | @tsv' \
  | while IFS=$'\t' read -r name path; do
      local branch marker disp has_bell='' dname
      dname="${name%%_worktrees*}" # display just the repo (branch shows in its own column); $name stays the connect target
      branch=$(git -C "$path" symbolic-ref --short -q HEAD 2>/dev/null)
      case $'\n'"$bells"$'\n' in *$'\n'"$name"$'\n'*) has_bell=1 ;; esac
      # Leftmost 2-col marker: ▶ for the current session, 🔔 for a session with a
      # pending bell, blank otherwise (▶+space, 🔔, and two spaces are all 2 cells
      # wide, so the repo column stays aligned). ▶ wins if the current session
      # also has a bell — you're already looking at it.
      if [ "$name" = "$cur" ]; then
        marker=$'\033[32m▶\033[0m ' ; disp=$'\033[1;36m'"$dname"$'\033[0m'
      elif [ -n "$has_bell" ]; then
        marker=$'\033[33m🔔\033[0m' ; disp="$dname"
      else
        marker='  ' ; disp="$dname"
      fi
      [ -n "$branch" ] && branch=$' \033[2m '"$branch"$'\033[0m'
      printf '%s\t%s%s%s\n' "$name" "$marker" "$disp" "$branch"
    done
}

list_all() {
  { if command -v zoxide >/dev/null 2>&1; then sesh list -d --icons
    else sesh list -t -c -d --icons; fi; } | dup
}

case "$1" in
  --list)
    case "$2" in
      all)    list_all ;;
      config) sesh list -c --icons | dup ;;
      dir)    sesh list -z --icons | dup ;;
      *)      list_tmux ;;
    esac
    exit 0 ;;
  --refresh-all)
    # F5 only the pickers that are actually on screen (active window of an
    # attached session) so background panes don't churn / trip monitor-activity.
    tmux list-panes -a \
      -f '#{&&:#{@sesh_picker},#{&&:#{window_active},#{session_attached}}}' \
      -F '#{pane_id}' 2>/dev/null | while read -r p; do
        tmux send-keys -t "$p" F5
      done
    exit 0 ;;
  --resize-all)
    # Pin every on-screen picker back to 40 columns. Needed because a session
    # created detached is only 80 cols wide (default-size); splitting -l 40 there
    # then attaching grows the window and tmux redistributes space *proportionally*,
    # turning the fixed 40 into ~40%. Re-asserting the width once the window is at
    # its full client size (see the client-session-changed / window-resized hooks
    # in tmux.conf) makes it a true 40 again.
    tmux list-panes -a \
      -f '#{&&:#{@sesh_picker},#{&&:#{window_active},#{session_attached}}}' \
      -F '#{pane_id}' 2>/dev/null | while read -r p; do
        tmux resize-pane -t "$p" -x 40
      done
    exit 0 ;;
  --focus)
    # focus the picker pane in the current window, or create it if there isn't one
    win=$(tmux display-message -p '#{window_id}' 2>/dev/null)
    pick=$(tmux list-panes -t "$win" -f '#{@sesh_picker}' -F '#{pane_id}' 2>/dev/null | head -1)
    if [ -n "$pick" ]; then
      tmux select-pane -t "$pick"
    else
      tmux split-window -hb -l 40 -t "$win" "exec $self"
    fi
    exit 0 ;;
esac

# ---- interactive picker ----------------------------------------------------

# Mark this pane so tmux can auto-close the window once the picker is the only
# pane left (see the window-layout-changed hook in tmux.conf).
[ -n "$TMUX_PANE" ] && tmux set-option -p -t "$TMUX_PANE" @sesh_picker 1 2>/dev/null

if command -v zoxide >/dev/null 2>&1; then
  header='^a all  ^t tmux  ^g conf  ^x dir'
  extra_binds=(--bind "ctrl-x:change-prompt(📁 )+reload($self --list dir)")
else
  header='^a all  ^t tmux  ^g conf'
  extra_binds=()
fi

# Reload the view matching the current prompt; f5 is sent by tmux on focus and
# on session create/close (see tmux.conf), so the list stays fresh.
reload_current="case \"\$FZF_PROMPT\" in *🌐*) $self --list all ;; *⚙*) $self --list config ;; *📁*) $self --list dir ;; *) $self --list tmux ;; esac"

# Cursor follows tmux focus. fzf can't dim its current-line background at runtime,
# so there's no background at all (--color current-bg:-1), the always-on gutter
# bar is blanked (--gutter ' '), and a thin bar (the pointer) is the only cursor
# — shown only while this picker pane has focus. It's recomputed on every f5
# (sent on focus change / list refresh by the tmux hooks) by querying this pane's
# #{pane_active}. Start hidden when spawned unfocused.
ptr_shown='▌'; ptr_hidden=' '
set_ptr="if [ \"\$(tmux display-message -p -t \"\$TMUX_PANE\" '#{pane_active}' 2>/dev/null)\" = 1 ]; then echo 'change-pointer($ptr_shown)'; else echo 'change-pointer($ptr_hidden)'; fi"
if [ -n "$TMUX_PANE" ] && [ "$(tmux display-message -p -t "$TMUX_PANE" '#{pane_active}' 2>/dev/null)" != 1 ]; then
  ptr="$ptr_hidden"
else
  ptr="$ptr_shown"
fi

while true; do
  line=$(
    "$self" --list tmux | fzf \
      --ansi --no-sort --no-hscroll --layout=reverse --border --delimiter '\t' --with-nth 2 \
      --border-label ' sessions ' \
      --pointer "$ptr" --gutter ' ' --color 'current-bg:-1,current-fg:-1' \
      --header "$header" \
      --bind 'tab:down,btab:up' \
      --bind 'ctrl-l:execute-silent(tmux select-pane -R)' \
      --bind "f5:transform($set_ptr)+reload($reload_current)" \
      --bind "ctrl-a:reload($self --list all)" \
      --bind "ctrl-t:reload($self --list tmux)" \
      --bind "ctrl-g:reload($self --list config)" \
      "${extra_binds[@]}"
  ) || break
  name=${line%%$'\t'*}
  [ -n "$name" ] && sesh connect "$name"
done
