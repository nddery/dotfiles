# Ghostty config.
# Symlinked to ~/.config/ghostty by symlinks.sh.
#
# Ghostty verifies/dumps its resolved config with:
#   ghostty +show-config
#   ghostty +show-config --default   # every key and its default
#   ghostty +list-themes             # built-in themes

# --- Font ---
font-family = "CaskaydiaCove Nerd Font"
font-size = 16
# Tune cell metrics if line spacing/width feels off.
# adjust-cell-width = 1
# adjust-cell-height = 3

# --- Cursor ---
cursor-style = block
cursor-style-blink = false
# Ghostty's shell integration forces a *bar* cursor at the prompt by default.
# Disable that one feature so cursor-style = block holds at the prompt; nvim &
# other apps can still set their own shape.
shell-integration-features = no-cursor
# Hollow cursor when the window is unfocused is Ghostty's default behavior.

# --- Terminal / compatibility ---
# Keep xterm-256color so SSH to hosts that lack the xterm-ghostty terminfo
# entry keeps working. TERM_PROGRAM stays "ghostty".
term = xterm-256color

# --- Scrolling ---
mouse-scroll-multiplier = 3
# NOTE: scrollback-limit is in BYTES (default ~10MB), not lines. The default
# already comfortably exceeds 10k lines.

# --- Mouse ---
mouse-hide-while-typing = false
# Middle-click paste-of-selection is default behavior.

# --- Window ---
window-decoration = true
background-opacity = 1.0
window-width = 100
window-height = 30
window-padding-x = 5
window-padding-y = 5
# Native titlebar; hide the macOS proxy (folder) icon; freeze the title to
# "ghostty" (remove the title line to show cwd / running program).
macos-titlebar-style = native
macos-titlebar-proxy-icon = hidden
title = "ghostty"

# --- Keybindings (CSI-u sequences for nvim & modern TUIs) ---
# text: uses Zig string-literal escapes, so \x1b == ESC.
keybind = shift+enter=text:\x1b[13;2u
keybind = ctrl+enter=text:\x1b[13;5u
keybind = kp_enter=text:\n

# --- Colors ---
# The active theme line below is rewritten by change_color_scheme()
# (zsh/functions.zsh) between themes/dark and themes/light.
# Relative path resolves next to this config file; if your Ghostty build doesn't
# resolve it, switch to the absolute form: ~/.config/ghostty/themes/dark
config-file = themes/dark
